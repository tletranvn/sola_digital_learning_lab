# ============================================================
#  .gitignore — Sola - Digital Learning Lab
# ============================================================

# --- Docs personnels (préparation entretien, non publics) ---
/docs-perso

# --- Secrets & variables d'environnement -------------------
# JAMAIS committer de clés / secrets (STITCH_API_KEY, clés LTI, etc.)
.env
.env.*
# On garde les exemples sans valeurs réelles, y compris le banc Moodle.
!**/.env.example
*.local

# --- Clés & certificats ------------------------------------
*.pem
*.key
*.p12
*.pfx
/keys/
/secrets/

# --- Node / npm / pnpm / yarn ------------------------------
node_modules/
.npm/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.yarn/

# --- Build & bundlers (Next.js / React) --------------------
.next/
out/
dist/
build/
.vite/
.cache/
*.tsbuildinfo

# --- Tests & couverture ------------------------------------
coverage/
.nyc_output/
playwright-report/
test-results/

# --- Docker : données persistantes du banc de test Moodle --
moodledata/
/data/
*-data/
db-data/
postgres-data/
mariadb-data/

# Captures locales de l'ancien prototype Moodle.
/integrations/moodle/legacy/*.png

# --- Logs --------------------------------------------------
logs/
*.log

# --- Système d'exploitation --------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Éditeurs / IDE ----------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json     # on peut partager les extensions recommandées
*.swp
*.swo
*~

# --- Divers ------------------------------------------------
tmp/
.temp/

docs-perso/


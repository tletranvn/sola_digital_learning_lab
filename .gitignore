# ============================================================
#  .gitignore — projet e-learning (Moodle + mini app LTI)
# ============================================================

# --- Docs personnels (préparation entretien, non publics) ---
/docs-perso

# --- Secrets & variables d'environnement -------------------
# JAMAIS committer de clés / secrets (STITCH_API_KEY, clés LTI, etc.)
.env
.env.*
!.env.example          # on garde l'exemple sans valeurs réelles
*.local

# --- Clés & certificats (clé privée LTI, TLS...) -----------
*.pem
*.key
*.p12
*.pfx
/keys/
/secrets/

# --- Node / npm / pnpm / yarn ------------------------------
node_modules/
.npm/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.yarn/

# --- Build & bundlers (Vite / React) -----------------------
dist/
build/
.vite/
.cache/
*.tsbuildinfo

# --- Tests & couverture ------------------------------------
coverage/
.nyc_output/
playwright-report/
test-results/

# --- Docker : données persistantes montées en local -------
# (ne pas versionner les volumes de données Moodle / BDD)
moodledata/
/data/
*-data/
db-data/
postgres-data/
mariadb-data/

# --- Logs --------------------------------------------------
logs/
*.log

# --- Système d'exploitation --------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Éditeurs / IDE ----------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json     # on peut partager les extensions recommandées
*.swp
*.swo
*~

# --- Divers ------------------------------------------------
tmp/
.temp/

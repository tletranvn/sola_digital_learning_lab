
# --- Base de données (MariaDB) ---
# Required: set a strong local value in .env.
DB_ROOT_PASSWORD=
DB_NAME=moodle
DB_USER=moodle
# Required: set a strong local value in .env.
DB_PASSWORD=

# --- Moodle : réseau / site ---
MOODLE_HTTP_PORT=8088
MOODLE_URL=http://localhost:8088
MOODLE_SITE_FULLNAME=Sagesse face à l'adversité
MOODLE_SITE_SHORTNAME=SFA
MOODLE_SITE_LANG=fr

# --- Moodle : compte administrateur ---
MOODLE_ADMIN_USER=admin
# Required: set a strong local value in .env.
MOODLE_ADMIN_PASS=
MOODLE_ADMIN_EMAIL=admin@example.com
